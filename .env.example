# .env.local — Required Environment Variables
# ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit this file to git. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────
# Your Google Gemini API key.
# Get one free at: https://aistudio.google.com/apikey
#
# WITHOUT this key: the app runs in "Local Playground Mode" — 
#   all pitch generation returns smart mock data, so the UI is fully functional.
#
# WITH this key: the app calls the real Gemini 2.5 Flash model for AI generation.
#
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required Database ────────────────────────────────────────────────────────
# PostgreSQL Connection URL
# Replace username, password, host, port, and database name with your credentials.
#
DATABASE_URL="postgresql://username:password@localhost:5432/pitch_generator?schema=public"

# ── Optional ───────────────────────────────────────────────────────────────
# Public app name (safe to expose to browser — uses NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_NAME="Synthesis AI"
